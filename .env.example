# Ці значення НЕ зберігаються в коді сайту - вони задаються
# в Vercel -> Project -> Settings -> Environment Variables.

# Telegram-бот - заявки з калькулятора і магазину
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Monobank Acquiring - токен з особистого кабінету https://web.monobank.ua/
# (Бізнес -> Налаштування -> API). Без цього токена кнопка оплати картою
# покаже клієнту повідомлення "оплата тимчасово недоступна" - сайт працює нормально.
MONOBANK_TOKEN=

# ───────────────────────────────────────────────────────────
# АДМІН-ПАНЕЛЬ (sunpower-ua.vercel.app/?admin=1)
# ───────────────────────────────────────────────────────────

# Логін/пароль адмінки - придумай самостійно щось складне, не "admin/admin"
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Випадковий довгий рядок для підпису сесійних кук адмінки.
# Згенеруй один раз і збережи, наприклад командою: openssl rand -hex 32
SESSION_SECRET=

# ───────────────────────────────────────────────────────────
# БАЗА ДАНИХ (Vercel KV) - для заявок і каталогу товарів
# ───────────────────────────────────────────────────────────
# Ці 2 змінні Vercel додає АВТОМАТИЧНО, коли ти підключаєш KV-базу:
# Vercel Dashboard -> твій проєкт -> Storage -> Create Database -> KV
# -> Connect Project. Тобі НЕ треба вписувати їх вручну.
#
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
#
# Без підключеної KV сайт продовжує працювати на вбудованому резервному
# каталозі товарів (SEED_PRODUCTS), просто заявки/зміни цін не зберігаються.

# ───────────────────────────────────────────────────────────
# АНАЛІТИКА (опціонально) - Google Analytics / Google Ads / Meta Pixel
# ───────────────────────────────────────────────────────────
# Без цих значень аналітика просто не підключається, сайт працює нормально.
# GA4: https://analytics.google.com -> Адмін -> Потоки даних -> ID потоку (G-XXXXXXXXXX)
VITE_GA4_ID=

# Google Ads: https://ads.google.com -> Інструменты -> Конверсії (AW-XXXXXXXXXX)
VITE_GOOGLE_ADS_ID=
VITE_GOOGLE_ADS_LEAD_LABEL=
VITE_GOOGLE_ADS_PURCHASE_LABEL=

# Meta Pixel: https://business.facebook.com/events_manager -> ID пікселя
VITE_META_PIXEL_ID=

# ───────────────────────────────────────────────────────────
# EMAIL-ДУБЛЮВАННЯ ЗАЯВОК (опціонально, але рекомендовано)
# ───────────────────────────────────────────────────────────
# Резервна копія заявок на email - якщо пропустиш Telegram, побачиш у пошті.
# 1. Увімкни 2FA на акаунті sun.power.ua1@gmail.com (Налаштування Google -> Безпека)
# 2. Створи App Password: https://myaccount.google.com/apppasswords
#    (звичайний пароль від Gmail тут НЕ підійде - Google його заблокує)
EMAIL_USER=sun.power.ua1@gmail.com
EMAIL_PASS=
EMAIL_TO=sun.power.ua1@gmail.com
